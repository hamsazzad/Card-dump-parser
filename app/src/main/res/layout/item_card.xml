<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="12dp"
    android:layout_marginBottom="12dp">

    <!-- Index badge at top left -->
    <TextView
        android:id="@+id/indexBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textStyle="bold"
        android:textColor="#000000"
        android:background="#ffffff"
        android:padding="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Card subtitle -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/card_data_header"
        android:textSize="10sp"
        android:textColor="#888888"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- Name row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/nameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#f1f1f1"
            android:textStyle="bold"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/copyName"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_copy"
            android:tint="#d4af37"
            android:contentDescription="Copy name" />
    </LinearLayout>

    <!-- Number row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/numberText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:textSize="16sp"
            android:fontFamily="monospace" />

        <ImageButton
            android:id="@+id/copyNumber"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_copy"
            android:tint="#d4af37"
            android:contentDescription="Copy number" />
    </LinearLayout>

    <!-- Bottom row with expiry and CVV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Expiry group -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/expiry"
                android:textSize="10sp"
                android:textColor="#777777"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/expiryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#eeeeee"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <ImageButton
                    android:id="@+id/copyExpiry"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_copy"
                    android:tint="#d4af37"
                    android:contentDescription="Copy expiry" />
            </LinearLayout>
        </LinearLayout>

        <!-- CVV group -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cvv"
                android:textSize="10sp"
                android:textColor="#777777"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/cvvText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#eeeeee"
                    android:textStyle="bold"
                    android:textSize="14sp" />
                <ImageButton
                    android:id="@+id/copyCvv"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_copy"
                    android:tint="#d4af37"
                    android:contentDescription="Copy cvv" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>